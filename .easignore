# EAS Build upload ignore rules
# This repo is a monorepo; exclude local caches/venvs that are not needed for mobile builds
# and can cause permission errors on Windows during tarball creation.

.git/
.vscode/
.idea/

.tmp/
__pycache__/
.pytest_cache/
pytest-cache-files-*/
backend/.pytest_cache/
backend/pytest-cache-files-*/

.venv/
backend/.venv/
backend/.venv-test/

node_modules/
frontend/node_modules/
frontend/.expo/
frontend/.npm-cache/

*.log
*.db
nightrecall.db
backend/nightrecall.db

