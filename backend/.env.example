APP_NAME=NightRecall API
ENVIRONMENT=development
API_V1_PREFIX=/v1
DATABASE_URL=postgresql+psycopg://nightrecall:nightrecall@localhost:5432/nightrecall
CORS_ORIGINS=["https://night-recall.vercel.app"]
DEFAULT_LOCALE=en
DEFAULT_TIMEZONE=UTC
LLM_PROVIDER=stub
LLM_MODEL=deterministic-fallback
OPENAI_API_KEY=
OPENAI_VISION_MODEL=gpt-4.1-mini
JWT_SECRET_KEY=change-me
JWT_ACCESS_TOKEN_TTL_MINUTES=30
JWT_REFRESH_TOKEN_TTL_DAYS=30
JOB_INLINE_PROCESSING=true
JOB_WORKER_POLL_INTERVAL_SECONDS=2.0
# Local default. In Railway, set this to your mounted volume path, for example /data/source-images.
SOURCE_IMAGE_STORAGE_ROOT=./storage/source-images
GOOGLE_WEB_CLIENT_ID=
GOOGLE_ANDROID_CLIENT_ID=
GOOGLE_IOS_CLIENT_ID=
ENABLE_GOOGLE_AUTH=true
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.0
OPS_ALERT_WINDOW_MINUTES=10
OPS_ALERT_THRESHOLD_5XX=3
OPS_ALERT_THRESHOLD_429=30
OPS_ALERT_THRESHOLD_SLOW=20
OPS_ALERT_THRESHOLD_EXCEPTION=1
OPS_ALERT_THRESHOLD_JOB_FAILED=1
OPS_ALERT_THRESHOLD_JOB_SLOW=10
